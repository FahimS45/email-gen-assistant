# OpenAI (Model A) 
OPENAI_API_KEY=YOUR_API_KEY
OPENAI_MODEL=gpt-5.4-mini-2026-03-17

# Ollama (Model B)
# Run `ollama serve` and `ollama pull qwen3:8b` before using this.
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen3:8b

# Embedding model (used for Metric 1 if use_embedding_fact_recall is True)
EMBEDDING_MODEL=text-embedding-3-small

# Judge model (used by Metric 2 in eval; always OpenAI)
JUDGE_MODEL=gpt-4o-mini

# FastAPI server 
APP_HOST=0.0.0.0
APP_PORT=8000
